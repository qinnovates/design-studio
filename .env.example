# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/design_studio?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# OAuth (optional — configure what you need)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AI key encryption
ENCRYPTION_KEY="generate-a-32-byte-hex-key"

# S3-compatible storage (optional — falls back to local)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
